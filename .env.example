# --- Alpaca (paper trading) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- AI providers ---
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Database ---
DATABASE_URL=

# --- App / cron ---
# Public base URL of the deployed app. Used by /api/trigger and the weekly
# routine to call /api/cron and /api/agent/review server-side. MUST be set in prod.
NEXT_PUBLIC_APP_URL=
# Shared secret guarding POST /api/cron (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=

# --- Telegram (outbound notifications via Cosmo Bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Open Brain write-bridge ---
# Base URL of the Mono API / Open Brain (e.g. https://mono-api-production-9db0.up.railway.app)
OPEN_BRAIN_URL=
# API key for the Open Brain HTTP bridge (sent as x-mono-key header).
MONO_API_KEY=

# --- Notion (optional) ---
NOTION_API_TOKEN=
NOTION_DATABASE_ID=

# --- Risk parameters (override guard defaults) ---
TRADING_ENABLED=true
MAX_DAILY_DRAWDOWN_PCT=3
MAX_POSITIONS=3
MAX_POSITION_SIZE_PCT=30

NODE_ENV=development
PORT=3000
